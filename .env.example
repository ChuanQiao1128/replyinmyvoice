# This repo is now a thin Next.js UI + BFF auth over the C#/Azure backend.
# All data, the rewrite engine, billing, and webhooks live in backend-dotnet/
# and are configured in Azure — they are NOT frontend env anymore.

# App
NEXT_PUBLIC_APP_URL=https://replyinmyvoice.com
NODE_ENV=development

# Auth — Entra External ID (the BFF session cookie is minted on the frontend/Worker)
AUTH_SESSION_SECRET=
ENTRA_CLIENT_SECRET=
NEXT_PUBLIC_ENTRA_AUTHORITY=
NEXT_PUBLIC_ENTRA_CLIENT_ID=
NEXT_PUBLIC_ENTRA_API_SCOPE=

# C#/Azure backend — the frontend proxies every data/compute call here
NEXT_PUBLIC_AZURE_API_BASE_URL=

# Cloudflare deploy
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
